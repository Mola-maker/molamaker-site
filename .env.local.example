# --- NetEase Music (Docker: deploy/netease/docker-compose.yml) ---
# Start with: docker compose -f deploy/netease/docker-compose.yml up -d
# Leave blank to fall back to direct music.163.com (may be geo-restricted)
NETEASE_API_URL=http://127.0.0.1:3100

# --- Claude / Anthropic ---
# Used by the Workplace Math assistant (Anthropic provider).
ANTHROPIC_API_KEY=sk-ant-

# --- AI providers (who uses what) ---
#
# | Surface                         | Provider chain                          | Config location        |
# |---------------------------------|-----------------------------------------|------------------------|
# | Live2D mascot (Workplace)       | AstrBot LLM only (persona injected)     | ASTRBOT_* env below    |
# | Floating chat (other variants)  | AstrBot → Coze → DeepSeek               | ASTRBOT_* + panel/env  |
# | Math / GeoGebra Studio          | Anthropic/DeepSeek/DashScope/Coze (any) | panel or *_API_KEY     |
# | Brand chat modal                | AstrBot only                            | ASTRBOT_* env below    |
#
# Workplace Settings panel edits Anthropic/DeepSeek/Coze only. AstrBot stays on the server.

# AstrBot (self-hosted on ECS) — Live2D + primary chat + uploads
ASTRBOT_INTERNAL_URL=http://<ECS-IP>:6185
ASTRBOT_API_KEY=abk_                       # AstrBot WebUI → Settings (chat + file scopes)

# Coze v3 — chat fallback + optional; also editable in Workplace Settings
COZE_API_KEY=pat_
COZE_BOT_ID=
COZE_BASE_URL=https://api.coze.cn          # or https://api.coze.com for international

# DeepSeek — chat fallback + Math provider; also editable in Workplace Settings
DEEPSEEK_API_KEY=sk-

# DashScope / 阿里百炼 (通义千问) — Math provider (OpenAI-compatible); also
# editable in Workplace Settings. Get a key at https://bailian.console.aliyun.com
# Default model qwen-plus. Base URL (Beijing): https://dashscope.aliyuncs.com/compatible-mode/v1
# (Singapore: https://dashscope-intl.aliyuncs.com/compatible-mode/v1)
# Optional fallback chain: DASHSCOPE_MODELS=qwen-plus,qwen-turbo,qwen-max
DASHSCOPE_API_KEY=sk-

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Auth ---
OWNER_EMAIL=

# --- Workplace ---
# Secret used to sign workplace session cookies (HMAC). Set a long random value.
WORKPLACE_SESSION_SECRET=
# Phone/email listed here is granted the 'owner' role at first login.
WORKPLACE_OWNER_PHONE=
# Shared admin key for direct owner sign-in (Workplace → "Admin key" tab).
# Generate a strong value, e.g.  openssl rand -hex 32
# Leave blank to disable admin-key sign-in entirely (fail closed).
WORKPLACE_ADMIN_KEY=

# --- Workplace · Phone OTP (Aliyun SMS / 阿里云短信) ---
# Required to actually deliver the 6-digit code in production. Without these,
# phone login only works in dev (the code is returned in the API response).
#   1. Console:   https://dysms.console.aliyun.com  → 国内消息
#   2. 签名(Sign): apply under 签名管理, wait for approval (e.g. 墨拉工坊)
#   3. 模板(Tmpl): apply under 模板管理; body must contain ${code},
#                  e.g. 您的验证码是${code}，10分钟内有效，请勿泄露。
#   4. AccessKey: create a RAM user at https://ram.console.aliyun.com,
#                 grant AliyunDysmsFullAccess, use its key/secret below.
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=          # approved 签名, e.g. 墨拉工坊
ALIYUN_SMS_TEMPLATE_CODE=      # approved 模板, e.g. SMS_123456789

# --- Workplace · WeChat QR login (微信开放平台 网站应用) ---
# Register a "网站应用" at https://open.weixin.qq.com (needs a verified company
# account, ¥300/yr). After approval you get AppID + AppSecret.
#   - 授权回调域 (callback domain): set to your bare host, e.g. molamaker.com
#     (no https://, no path)
#   - WECHAT_REDIRECT_URI must point at the callback route below (full URL)
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_REDIRECT_URI=https://your-domain.com/api/workplace/auth/wechat

# --- Workplace · Math (GeoGebra self-host) ---
# GeoGebra loads from /geogebra/ by default (public/geogebra/ — same as Live2D).
# Download the Math Apps Bundle and unzip the inner GeoGebra/ folder there:
#   https://download.geogebra.org/package/geogebra-math-apps-bundle
# public/geogebra/ is gitignored (~100 MB). CDN is tried only if /geogebra/ is missing.
# Optional: point at an ECS/OSS mirror instead of bundling locally:
#   NEXT_PUBLIC_GEOGEBRA_BASE_URL=https://bot.molamaker.com/geogebra
# See deploy/geogebra/SETUP.md.
NEXT_PUBLIC_GEOGEBRA_BASE_URL=

# --- Workplace · Live2D mascot (self-host) ---
# The bottom-left Live2D character (stevenjoezhang/live2d-widget) now loads from
# /live2d/ (local public/ folder) by default — self-hosting with 8 character groups
# and 26+ outfit variations. Set this to override for a remote host (ECS/OSS).
# See deploy/live2d/SETUP.md.
NEXT_PUBLIC_LIVE2D_BASE=

# Optional: disable in dev with MATH_PIPELINE_V2=0
# MATH_PIPELINE_V2=1 enables L0→L2 plan→L4 semantic audit on Math /draw
# MATH_GEOMETRY_ANALYSIS=1 enables analysis SSE only (legacy)
# MATH_PIPELINE_V2=1
#
# L1 semantics mode (default rules = instant, no blocking LLM before draw):
# MATH_L1_MODE=rules   — L0 rule-based semantics (recommended, fast)
# MATH_L1_MODE=hybrid  — rules first, optional LLM enrich ≤20s
# MATH_L1_MODE=llm     — blocking L1 LLM (slow; use MATH_SEMANTICS_MODEL=deepseek-chat)
# MATH_L1_FAST_ONLY=0  — allow user reasoning model for L1 (not recommended)
# MATH_SEMANTICS_MODEL=deepseek-chat
# MATH_SEMANTICS_TIMEOUT_MS=45000

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_AVATAR_URL=

# --- GitHub ---
GITHUB_TOKEN=
GITHUB_USERNAME=Mola-maker

# --- Buy Me a Coffee ---
NEXT_PUBLIC_BMAC_HANDLE=
BMAC_WEBHOOK_SECRET=

# --- Giscus (comments) ---
NEXT_PUBLIC_GISCUS_REPO=
NEXT_PUBLIC_GISCUS_REPO_ID=
NEXT_PUBLIC_GISCUS_CATEGORY_ID=
